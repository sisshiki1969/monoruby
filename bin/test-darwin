#!/bin/bash
#
# test-darwin — bin/test の native macOS (Apple Silicon / arm64-apple-darwin) 派生。
#
# bin/test は x86-64 Linux 前提: cargo llvm-cov でカバレッジを採り、JIT-only
# feature (stress-spill-pool) を有効化し、最後に codecov 用 lcov.info を吐く。
# macOS aarch64 には JIT が存在せず (build.rs が `jit` cfg を x86-64 のときだけ
# 立てる)、VM tier のみがビルドされる。本スクリプトはカバレッジを採らず、
# native arm64-apple-darwin 上で
#   1. cargo nextest (prism / ruruby parser 両方)
#   2. benchmark 出力を host ruby と diff
# を走らせる。bin/test-aarch64 は Linux target (qemu-user) 用なので darwin では
# 使えない — こちらは host = target = aarch64-apple-darwin で素直に走る。
#
# 前提:
#   - ruby >= 4.0 が PATH に居る (build.rs / テストの差分比較が使う)
#   - Homebrew の libffi + pkg-config
#       brew install libffi pkg-config
#     libffi は keg-only なので pkg-config に見せる必要がある:
#       export PKG_CONFIG_PATH="$(brew --prefix libffi)/lib/pkgconfig"
#
# 環境変数:
#   STRESS=1      gc-stress を有効化 (GC ストレステスト。実機でも数倍遅くなる)
#   SKIP_BENCH=1  benchmark 差分をスキップ (nextest だけ走らせる)
#   SKIP_HEAVY=1  optcarrot をスキップ (../optcarrot がある場合のみ走る)
set -e

say() { printf '\033[1;36m[test-darwin]\033[0m %s\n' "$*"; }

FEAT_ARGS=()
if [ "${STRESS:-0}" = "1" ]; then
  FEAT_ARGS=(--features gc-stress)
fi

# ---- 1. cargo nextest (prism / ruruby parser) ------------------------------

say "cargo nextest (prism parser, stress=${STRESS:-0})"
cargo nextest run "${FEAT_ARGS[@]}"
say "cargo nextest (ruruby parser)"
MONORUBY_PARSER=ruruby cargo nextest run "${FEAT_ARGS[@]}"

# ---- 2. benchmark 出力差分 -------------------------------------------------

if [ "${SKIP_BENCH:-0}" = "1" ]; then
  say "skipping benchmark diffs (SKIP_BENCH=1)"
  say "DONE"
  exit 0
fi

say "building release binary for benchmark diffs"
cargo build --release --bin monoruby
MONORUBY="$PWD/target/release/monoruby"

run_diff() {
  local label="$1" rb="$2"
  echo "=== $label ==="
  "$MONORUBY" "$rb" >/tmp/monoruby.log 2>/dev/null
  ruby "$rb" >/tmp/ruby.log
  diff -s /tmp/monoruby.log /tmp/ruby.log
}

run_diff app_fib      benchmark/app_fib.rb
run_diff tarai        benchmark/tarai.rb
run_diff so_nbody     benchmark/so_nbody.rb
run_diff plb2/nqueen  benchmark/plb2/nqueen.rb
run_diff plb2/sudoku  benchmark/plb2/sudoku.rb
run_diff plb2/matmul  benchmark/plb2/matmul.rb
run_diff plb2/bedcov  benchmark/plb2/bedcov.rb

# mandelbrot は --no-jit と通常の両方を host ruby と diff (bin/test と同じ)。
# aarch64 では JIT が存在しないので両者は同一だが、CLI の動作確認も兼ねる。
echo "=== so_mandelbrot ==="
"$MONORUBY" benchmark/so_mandelbrot.rb >/tmp/m1.ppm
"$MONORUBY" --no-jit benchmark/so_mandelbrot.rb >/tmp/m2.ppm
ruby benchmark/so_mandelbrot.rb >/tmp/r.ppm
diff -s /tmp/r.ppm /tmp/m1.ppm
diff -s /tmp/r.ppm /tmp/m2.ppm
rm -f /tmp/m1.ppm /tmp/m2.ppm /tmp/r.ppm

rm -f /tmp/monoruby.log /tmp/ruby.log

# ---- 3. optcarrot (../optcarrot がある場合のみ) -----------------------------

# Drop the trailing 3 (non-deterministic timing) lines. bin/test uses GNU
# `head -n -3`, but BSD/macOS `head` rejects negative counts, so strip them
# portably via awk (buffer 3 lines, never emit the final 3).
drop_last3() { awk 'NR>3{print buf[NR%3]} {buf[NR%3]=$0}'; }

if [ -d "../optcarrot" ] && [ "${SKIP_HEAVY:-0}" != "1" ]; then
  echo "=== optcarrot (--debug) ==="
  "$MONORUBY" ../optcarrot/bin/optcarrot -b --debug ../optcarrot/examples/Lan_Master.nes \
    | drop_last3 >/tmp/monoruby.log
  ruby ../optcarrot/bin/optcarrot -b --debug ../optcarrot/examples/Lan_Master.nes \
    | drop_last3 >/tmp/ruby.log
  diff -s /tmp/monoruby.log /tmp/ruby.log
  rm -f /tmp/monoruby.log /tmp/ruby.log
else
  say "skipping optcarrot (../optcarrot not present or SKIP_HEAVY=1)"
fi

say "DONE"
