#!/usr/bin/env bash
#
# Rebuild the `monoruby-vendored` branch of sisshiki1969/prism on top of
# the current `monoruby` branch tip and force-push it.
#
# Run after pushing changes to the fork's `monoruby` branch (Rust wrapper
# / bindgen allowlist). Afterwards, in the monoruby repo, run
# `cargo update -p ruby-prism` to pick up the new rev.
#
# Requirements:
#   - ssh access to git@github.com:sisshiki1969/prism.git (override with
#     FORK_URL=https://... if you prefer https + PAT)
#   - ruby + bundler in PATH

set -euo pipefail

FORK_URL="${FORK_URL:-git@github.com:sisshiki1969/prism.git}"
WORK_DIR="$(mktemp -d -t prism-refresh-XXXXXX)"
trap 'rm -rf "$WORK_DIR"' EXIT

echo "==> Cloning $FORK_URL into $WORK_DIR"
git clone --branch monoruby "$FORK_URL" "$WORK_DIR"
cd "$WORK_DIR"

echo "==> Installing prism Gemfile deps"
bundle install --quiet

echo "==> Generating C source via rake cargo:build"
bundle exec rake cargo:build

echo "==> Loosening .gitignore so vendor/ can be committed"
sed -i '/^vendor\/$/d' rust/ruby-prism-sys/.gitignore rust/ruby-prism/.gitignore
sed -i 's|^vendor/$|/vendor/|' .gitignore

echo "==> Committing populated vendor on top of monoruby tip"
git add -A
git commit -m "vendor: ship populated C source for cargo git-dep consumption

Branch consumed by monoruby as a \`ruby-prism\` git dependency. Cargo
clones the repo into ~/.cargo/git/checkouts and runs the unmodified
upstream \`vendored.rs\` build script, which expects
\`rust/ruby-prism-sys/vendor/prism-{ver}/{src,include}\` to exist. We
populate it with \`bundle exec rake cargo:build\` and check it in here
so the consumer needs neither bundler nor rake.

Kept off the \`monoruby\` branch to keep the upstream-bound diff
minimal (vendor/ is regenerated by upstream's release tooling)."

echo "==> Force-pushing monoruby-vendored"
git push -f "$FORK_URL" HEAD:monoruby-vendored

NEW_REV=$(git rev-parse HEAD)
echo
echo "Done. New monoruby-vendored HEAD: $NEW_REV"
echo "Next: in the monoruby repo, run \`cargo update -p ruby-prism\`."
