#!/bin/bash
set -e

# Portable helpers so this script runs unmodified on x86-64 Linux (CI's
# `coverage` job) and native arm64 macOS (the `darwin` job). On arm64 macOS
# build.rs sets the `jit` cfg, so this also exercises and coverage-measures the
# AArch64 JIT (asmir/compile_stub.rs).

# macOS/BSD `head` rejects `-n -3`; drop the last 3 (non-deterministic timing)
# lines with awk instead. Identical output to `head -n -3` on GNU.
drop_last3() { awk 'NR>3{print buf[NR%3]} {buf[NR%3]=$0}'; }

# Use YJIT when this ruby supports it (x86-64 Linux CI); fall back to plain ruby
# where the prebuilt has no YJIT (some arm64 macOS builds). YJIT changes speed,
# not semantics, so the output diffs are unaffected either way.
if ruby --yjit -e 'exit(defined?(RubyVM::YJIT) && RubyVM::YJIT.enabled? ? 0 : 1)' >/dev/null 2>&1; then
  RUBY=(ruby --yjit)
else
  RUBY=(ruby)
fi

# stress-spill-pool / gc-stress amplify the JIT's spill + GC paths. Under
# llvm-cov coverage instrumentation on the memory-constrained arm64 macOS CI
# runner, that combination trips a latent AArch64-JIT-under-stress corruption
# (a value is freed mid-flight -> String becomes INVALID(255) -> SIGABRT;
# tracked separately, deterministic only with coverage + both stress features).
# The x86-64 JIT is unaffected, so enable the stress features only there; other
# arches still build and coverage-measure the JIT, just without the amplifiers.
case "$(uname -m)" in
  x86_64) STRESS_FEATURES=(--features stress-spill-pool --features gc-stress) ;;
  *)      STRESS_FEATURES=() ;;
esac

cargo llvm-cov clean --workspace
cargo llvm-cov nextest "${STRESS_FEATURES[@]}" --no-report
MONORUBY_PARSER=ruruby cargo llvm-cov nextest "${STRESS_FEATURES[@]}" --no-report

cargo llvm-cov run --no-report -- --version > /dev/null
MONORUBY="$PWD/target/llvm-cov-target/debug/monoruby"

$MONORUBY benchmark/app_fib.rb > monoruby.log 2> /dev/null
"${RUBY[@]}" benchmark/app_fib.rb > ruby.log
diff -s monoruby.log ruby.log

# Build instrumented binary via cargo llvm-cov run
cargo llvm-cov run --no-report "${STRESS_FEATURES[@]}" -- --version > /dev/null

$MONORUBY benchmark/tarai.rb > monoruby.log
"${RUBY[@]}" benchmark/tarai.rb > ruby.log
diff -s monoruby.log ruby.log
$MONORUBY benchmark/so_nbody.rb > monoruby.log
"${RUBY[@]}" benchmark/so_nbody.rb > ruby.log
diff -s monoruby.log ruby.log
#$MONORUBY benchmark/bf.rb > monoruby.log
#"${RUBY[@]}" benchmark/bf.rb > ruby.log
#diff -s monoruby.log ruby.log

echo "checking plb2.."
$MONORUBY benchmark/plb2/nqueen.rb > monoruby.log
"${RUBY[@]}" benchmark/plb2/nqueen.rb > ruby.log
diff -s monoruby.log ruby.log
$MONORUBY benchmark/plb2/sudoku.rb > monoruby.log
"${RUBY[@]}" benchmark/plb2/sudoku.rb > ruby.log
diff -s monoruby.log ruby.log
$MONORUBY benchmark/plb2/matmul.rb > monoruby.log
"${RUBY[@]}" benchmark/plb2/matmul.rb > ruby.log
diff -s monoruby.log ruby.log
$MONORUBY benchmark/plb2/bedcov.rb > monoruby.log
"${RUBY[@]}" benchmark/plb2/bedcov.rb > ruby.log
diff -s monoruby.log ruby.log

$MONORUBY benchmark/so_mandelbrot.rb > benchmark/mandel1.ppm
$MONORUBY --no-jit benchmark/so_mandelbrot.rb > benchmark/mandel2.ppm
"${RUBY[@]}" benchmark/so_mandelbrot.rb > benchmark/mandel.ppm
diff -s benchmark/mandel.ppm benchmark/mandel1.ppm
diff -s benchmark/mandel.ppm benchmark/mandel2.ppm
rm benchmark/*.ppm

$MONORUBY ../optcarrot/bin/optcarrot -b --debug ../optcarrot/examples/Lan_Master.nes | drop_last3 > monoruby.log
"${RUBY[@]}" ../optcarrot/bin/optcarrot -b --debug ../optcarrot/examples/Lan_Master.nes | drop_last3 > ruby.log
diff -s monoruby.log ruby.log

$MONORUBY ../optcarrot/bin/optcarrot -b --opt --debug ../optcarrot/examples/Lan_Master.nes | drop_last3 > monoruby.log
"${RUBY[@]}" ../optcarrot/bin/optcarrot -b --opt --debug ../optcarrot/examples/Lan_Master.nes | drop_last3 > ruby.log
diff -s monoruby.log ruby.log
rm *.log

# Run the ruby-bench output-diff harness if the ruby-bench checkout is
# present alongside this repo. Reuses the already-built instrumented
# monoruby and the `ruby` from PATH; exits non-zero on output mismatch.
if [ -d "../ruby-bench/benchmarks" ]; then
  echo "Running ruby-bench output diff..."
  MONORUBY="$MONORUBY" CRUBY=ruby bin/ruby-bench-diff
fi

# Run ruby/spec with instrumented binary for coverage
if [ -d "../spec" ] && [ -d "../mspec" ]; then
  echo "Running ruby/spec for coverage..."
  cd ../spec
  for cat in basicobject true false nil integer float comparable math builtin_constants class numeric rational struct symbol range set systemexit; do
    echo "=== core/$cat ==="
    ../mspec/bin/mspec core/$cat -t "$MONORUBY"
  done
  cd "$OLDPWD"
fi

cargo llvm-cov report --lcov --output-path lcov.info
rm *.profraw
